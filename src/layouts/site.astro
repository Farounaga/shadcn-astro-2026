---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/ui/button"

interface Props {
  title?: string
}

const { title } = Astro.props
const pathname = Astro.url.pathname

const menuItems = [
  { href: "/presentation", label: "Présentation" },
  { href: "/veille", label: "Veille" },
  { href: "/contact", label: "Contact & Informations" },
]
---

<Layout title={title}>
  <header class="sticky top-0 z-20 border-b bg-background/90 backdrop-blur">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      <a href="/" class="text-sm font-semibold tracking-wide">VS</a>
      <nav class="flex flex-wrap items-center gap-2">
        {
          menuItems.map((item) => (
            <Button
              asChild
              variant={pathname.startsWith(item.href) && item.href !== "/" ? "default" : pathname === item.href ? "default" : "outline"}
              size="sm"
            >
              <a href={item.href}>{item.label}</a>
            </Button>
          ))
        }
      </nav>
    </div>
  </header>
  <main class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-10">
    <slot />
  </main>
</Layout>
